{
  "name": "trazo",
  "version": "1.0.0",
  "description": "Numerical methods library for mathematics and engineering applications",
  "main": "dist/trazo.cjs.js",
  "module": "dist/trazo.esm.js",
  "type": "module",
  "exports": {
    ".": {
      "require": "./dist/trazo.cjs.js",
      "import": "./dist/trazo.esm.js"
    }
  },
  "scripts": {
    "start": "node src/index.js",
    "build": "rollup -c",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config=\"{\\\"testMatch\\\":[\\\"**/*.test.js\\\"],\\\"passWithNoTests\\\":true}\"",
    "test:watch": "jest --watch tests",
    "test:cov": "jest --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "typecheck": "tsc -p jsconfig.json --noEmit"
  },
  "keywords": [
    "numerical-methods",
    "mathematics",
    "engineering"
  ],
  "homepage": "https://github.com/sis-inf/trazo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sis-inf/trazo.git"
  },
  "bugs": {
    "url": "https://github.com/sis-inf/trazo/issues"
  },
  "author": "sis-inf",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "rollup": "^4.0.0"
  }
}
